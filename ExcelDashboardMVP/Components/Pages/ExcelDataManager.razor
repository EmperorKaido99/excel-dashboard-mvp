@page "/data-table"
@rendermode InteractiveServer
@using ExcelDashboardMVP.Models
@using ExcelDashboardMVP.Services
@using Microsoft.JSInterop
@using OfficeOpenXml
@using OfficeOpenXml.Style
@inject ExcelDataService DataService
@inject AiAgentService AiAgent
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject ILogger<ExcelDataManager> Logger
@implements IDisposable

<PageTitle>Data Table</PageTitle>

<style>
    .xpage { padding: 12px 16px; box-sizing: border-box; }

    .xcard {
        width: 100%; max-width: 1600px; margin: 0 auto;
        background: white; border: 1px solid #d0d8f0;
        border-radius: 10px; box-shadow: 0 2px 8px rgba(30,35,147,.08);
        display: flex; flex-direction: column;
    }

    /* Toolbar */
    .xtb {
        flex-shrink: 0; background: #f5f7ff;
        border-bottom: 1px solid #d0d8f0;
        border-radius: 10px 10px 0 0; padding: 8px 14px;
    }
    .xtb-row { display: flex; flex-wrap: wrap; align-items: center; gap: 6px; }

    /* Scrollable table area */
    .xbody { overflow: auto; max-height: calc(100vh - 230px); min-height: 200px; }

    /* Pagination footer */
    .xfoot {
        flex-shrink: 0; background: #f8f9ff;
        border-top: 2px solid #c0caed;
        border-radius: 0 0 10px 10px;
        padding: 6px 14px;
        display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    }

    /* Table */
    .xt { border-collapse: collapse; width: 100%; font-size: 13px; }
    .xt th {
        position: sticky; top: 0; z-index: 10;
        background: #eef2ff; border: 1px solid #c4cfff;
        padding: 5px 8px; font-size: 12px; font-weight: 600;
        white-space: nowrap; user-select: none; cursor: pointer;
    }
    .xt th:hover { background: #d8e2ff; }
    .xt th.nc { cursor: default; }
    .xt .frow th {
        top: 29px; background: #fffbf2; padding: 2px 3px;
        cursor: default; border-top: 2px solid #e8d080; z-index: 9;
    }
    .xt td {
        border: 1px solid #e4e8f8; padding: 3px 7px;
        white-space: nowrap; max-width: 200px;
        overflow: hidden; text-overflow: ellipsis;
        cursor: cell; font-size: 13px; height: 26px;
    }
    .xt tr:nth-child(even) td { background: #f9faff; }
    .xt tr:hover td { background: #edf3ff !important; }
    .xt tr.xsel td { background: #d4e6ff !important; }
    .xt td.xedit { padding: 0 !important; overflow: visible; }
    .xt td.xedit input {
        width: 100%; min-width: 100px; border: 2px solid #1074d6; outline: none;
        padding: 3px 6px; font-size: 13px; font-family: inherit;
        background: white; box-sizing: border-box; display: block; height: 26px;
    }
    .xt .xrn {
        background: #f0f0f4 !important; color: #888; text-align: center;
        width: 38px; min-width: 38px; cursor: default; font-size: 11px;
        position: sticky; left: 0; z-index: 5;
    }
    .xt th.xrn { z-index: 11; }
    .xt .xac { width: 68px; min-width: 68px; cursor: default; text-align: center; }
    .xt .xaddcol {
        cursor: pointer; border-left: 2px dashed #90a8ff !important;
        color: #1074d6; text-align: center; width: 34px; min-width: 34px;
    }
    .xt .xaddcol:hover { background: #dde8ff !important; }
    .xfi {
        width: 100%; box-sizing: border-box; border: 1px solid #ddd;
        border-radius: 3px; padding: 2px 4px; font-size: 11px;
        font-family: inherit; background: white;
    }
    .xfi:focus { border-color: #1074d6; outline: none; background: #fff8e8; }
    .xsi { color: #1074d6; margin-left: 3px; font-size: 10px; }
    .xchip { display: inline-block; border-radius: 12px; padding: 1px 8px; font-size: 11px; font-weight: 500; }
    .xchip-y { background: #fff3cd; color: #856404; }
    .xchip-f { background: #f3e8ff; color: #7c3aed; }
    .xchip-m { background: #e0f2fe; color: #0369a1; }

    /* Row action buttons */
    .xbtn {
        display: inline-flex; align-items: center; justify-content: center;
        border: none; background: transparent; cursor: pointer;
        padding: 3px 6px; border-radius: 4px; font-size: 15px; line-height: 1;
    }
    .xbtn-edit { color: #1074d6; }
    .xbtn-edit:hover { background: #e0edff; }
    .xbtn-del { color: #d32f2f; }
    .xbtn-del:hover { background: #fde8e8; }

    /* Toolbar buttons */
    .tbtn {
        display: inline-flex; align-items: center; gap: 4px;
        border-radius: 5px; padding: 5px 11px; font-size: 12px;
        font-weight: 500; cursor: pointer; white-space: nowrap;
        border: 1px solid currentColor; background: white;
        font-family: inherit; transition: opacity .15s;
    }
    .tbtn:hover:not(:disabled) { opacity: .8; }
    .tbtn:disabled { opacity: .4; cursor: default; }
    .tbtn-primary { background: #1074d6; color: white; border-color: #1074d6; }
    .tbtn-info    { color: #0369a1; border-color: #0369a1; }
    .tbtn-success { color: #2e7d32; border-color: #2e7d32; }
    .tbtn-warn    { color: #ed6c02; border-color: #ed6c02; }
    .tbtn-warn-on { background: #ed6c02; color: white; border-color: #ed6c02; }
    .tbtn-err     { color: #d32f2f; border-color: #d32f2f; }
    .tbtn-sec     { color: #1e2393; border-color: #1e2393; }
    .tbtn-muted   { color: #666; border-color: #aaa; }

    /* Search */
    .xsearch {
        border: 1px solid #c4cfff; border-radius: 5px; padding: 5px 10px;
        font-size: 13px; width: 200px; font-family: inherit;
    }
    .xsearch:focus { border-color: #1074d6; outline: none; }

    /* Badges */
    .xbadge {
        display: inline-block; border-radius: 8px; padding: 1px 8px;
        font-size: 11px; font-weight: 600;
    }
    .xbadge-blue   { background: #eef2ff; color: #1e2393; }
    .xbadge-orange { background: #fff3e0; color: #e65100; }
    .xbadge-ai     { background: #e8f5e9; color: #2e7d32; }

    /* Pagination */
    .pgbtn {
        border: 1px solid #c0caed; border-radius: 4px; background: white;
        padding: 3px 9px; cursor: pointer; font-size: 14px; color: #1074d6;
        font-family: inherit;
    }
    .pgbtn:hover:not(:disabled) { background: #eef2ff; }
    .pgbtn:disabled { opacity: .35; cursor: default; }
    .pgsel { border: 1px solid #c0caed; border-radius: 4px; padding: 4px 6px; font-size: 12px; font-family: inherit; }

    /* ─── PURE CSS MODALS ─── */
    .xbackdrop {
        position: fixed; inset: 0; z-index: 99999;
        background: rgba(0,0,0,.5);
        display: flex; align-items: center; justify-content: center;
    }
    .xmodal {
        background: white; border-radius: 12px; padding: 28px 32px;
        width: 92vw; max-width: 860px; max-height: 90vh;
        overflow-y: auto; position: relative;
        box-shadow: 0 12px 48px rgba(0,0,0,.35);
    }
    .xmodal-sm { max-width: 440px; }
    .xmodal-title {
        font-size: 1.05rem; font-weight: 700; color: #1e2393;
        margin: 0 0 20px 0;
    }
    .xclose {
        position: absolute; top: 14px; right: 16px;
        border: none; background: none; cursor: pointer;
        font-size: 20px; color: #888; line-height: 1; font-family: inherit;
    }
    .xclose:hover { color: #333; }
    .xform-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    @@media (max-width:600px) { .xform-grid { grid-template-columns: 1fr; } }
    .xfield { display: flex; flex-direction: column; gap: 4px; }
    .xfield label { font-size: 12px; font-weight: 600; color: #444; }
    .xfield input, .xfield select {
        border: 1px solid #c4cfff; border-radius: 5px;
        padding: 7px 10px; font-size: 13px; font-family: inherit;
    }
    .xfield input:focus, .xfield select:focus {
        border-color: #1074d6; outline: none;
        box-shadow: 0 0 0 2px rgba(16,116,214,.15);
    }
    .xmodal-footer { display: flex; justify-content: flex-end; gap: 10px; margin-top: 24px; }
    .xdivider { width: 1px; height: 24px; background: #c4cfff; display: inline-block; }
</style>

@* ═══════════════════════════════════════════════
   MODALS — fixed position, bypasses overflow / z-index
   ═══════════════════════════════════════════════ *@

@* Add / Edit Row *@
@if (_showRowDialog && _dialogRecord != null)
{
    <div class="xbackdrop" @onclick="CloseRowDialog">
        <div class="xmodal" @onclick:stopPropagation="true">
            <button class="xclose" @onclick="CloseRowDialog" type="button">✕</button>
            <div class="xmodal-title">
                @(_isNewRecord ? "➕ Add New Row" : $"✏️ Edit Row #{_dialogRecord.RowNumber}")
            </div>

            <div class="xform-grid">
                <div class="xfield"><label>Name *</label>
                    <input @bind="_dialogRecord.Name" placeholder="First name" /></div>
                <div class="xfield"><label>Surname *</label>
                    <input @bind="_dialogRecord.Surname" placeholder="Last name" /></div>
                <div class="xfield"><label>Identifier (ID No.)</label>
                    <input @bind="_dialogRecord.Identifier" /></div>
                <div class="xfield"><label>Email Address</label>
                    <input type="email" @bind="_dialogRecord.EmailAddress" /></div>
                <div class="xfield"><label>Local Municipality</label>
                    <input @bind="_dialogRecord.LocalMunicipality" /></div>
                <div class="xfield"><label>Host Company</label>
                    <input @bind="_dialogRecord.HostCompany" /></div>
                <div class="xfield"><label>Lead Company</label>
                    <input @bind="_dialogRecord.LeadCompany" /></div>
                <div class="xfield"><label>Job Type</label>
                    <input @bind="_dialogRecord.JobType" /></div>
                <div class="xfield"><label>Demographic Group</label>
                    <input @bind="_dialogRecord.DemographicGroup" /></div>
                <div class="xfield"><label>Sex / Gender</label>
                    <select @bind="_dialogRecord.Sex">
                        <option value="">— Not specified —</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select></div>
                <div class="xfield"><label>Contact Details</label>
                    <input @bind="_dialogRecord.ContactDetails" /></div>
                <div class="xfield"><label>Employment Status</label>
                    <input @bind="_dialogRecord.EmploymentStatus" /></div>
                <div class="xfield"><label>Person Disability</label>
                    <select @bind="_dialogRecord.PersonDisability">
                        <option value="">— Not specified —</option>
                        <option value="Y">Yes — Has disability</option>
                        <option value="N">No</option>
                    </select></div>

                @foreach (var colName in _customColumnNames)
                {
                    var cn = colName;
                    <div class="xfield">
                        <label>@cn (custom)</label>
                        <input value="@(_dialogCustomValues.TryGetValue(cn, out var cv) ? cv : "")"
                               @oninput="e => _dialogCustomValues[cn] = e.Value?.ToString() ?? string.Empty" />
                    </div>
                }
            </div>

            <div class="xmodal-footer">
                <button class="tbtn tbtn-muted" type="button" @onclick="CloseRowDialog">Cancel</button>
                <button class="tbtn tbtn-primary" type="button" @onclick="SaveRow">
                    💾 @(_isNewRecord ? "Add Row" : "Save Changes")
                </button>
            </div>
        </div>
    </div>
}

@* Add Column *@
@if (_showColDialog)
{
    <div class="xbackdrop" @onclick="() => _showColDialog = false">
        <div class="xmodal xmodal-sm" @onclick:stopPropagation="true">
            <button class="xclose" @onclick="() => _showColDialog = false" type="button">✕</button>
            <div class="xmodal-title">➕ Add Custom Column</div>
            <div class="xfield">
                <label>Column Name</label>
                <input @bind="_newColName" @bind:event="oninput"
                       @onkeydown="HandleColKeyDown"
                       placeholder="e.g. Notes, Score, Flag" />
            </div>
            <div class="xmodal-footer">
                <button class="tbtn tbtn-muted" type="button" @onclick="() => _showColDialog = false">Cancel</button>
                <button class="tbtn tbtn-primary" type="button" @onclick="AddCustomColumn">Add Column</button>
            </div>
        </div>
    </div>
}

@* Confirm Delete *@
@if (_showDeleteConfirm && _deleteTarget != null)
{
    <div class="xbackdrop" @onclick="() => _showDeleteConfirm = false">
        <div class="xmodal xmodal-sm" @onclick:stopPropagation="true">
            <button class="xclose" @onclick="() => _showDeleteConfirm = false" type="button">✕</button>
            <div class="xmodal-title">🗑️ Delete Row</div>
            <p style="color:#555; margin:0 0 20px 0;">
                Delete row <strong>#@_deleteTarget.RowNumber</strong> —
                <strong>@_deleteTarget.Name @_deleteTarget.Surname</strong>?<br />
                <span style="color:#d32f2f; font-size:12px;">This cannot be undone.</span>
            </p>
            <div class="xmodal-footer">
                <button class="tbtn tbtn-muted" type="button" @onclick="() => _showDeleteConfirm = false">Cancel</button>
                <button class="tbtn" type="button"
                        style="background:#d32f2f; color:white; border-color:#d32f2f;"
                        @onclick="ExecuteDelete">
                    🗑️ Delete
                </button>
            </div>
        </div>
    </div>
}

@* ═══════════════════════════════════════════════
   MAIN PAGE
   ═══════════════════════════════════════════════ *@
<div class="xpage">
<div class="xcard">

    @* TOOLBAR *@
    <div class="xtb">
        <div class="xtb-row">
            <span style="font-weight:700; color:#1e2393; font-size:14px; margin-right:4px;">📊 Data Table</span>
            <span class="xbadge xbadge-blue">@_filtered.Count / @_allRecords.Count rows · @VisibleColumns.Count cols</span>
            @if (HasFilters)
            {
                <span class="xbadge xbadge-orange">@ActiveFilterCount filter(s) active</span>
            }
            @if (_aiFilterActive)
            {
                <span class="xbadge xbadge-ai">🤖 Dash filter</span>
            }

            <input class="xsearch"
                   placeholder="🔍 Search all columns..."
                   value="@_globalSearch"
                   @oninput="OnGlobalSearchInput" />

            <div style="flex:1; min-width:4px;"></div>

            <button class="tbtn tbtn-primary" type="button" @onclick="OpenAddRowDialog">➕ Add Row</button>
            <button class="tbtn tbtn-info"    type="button" @onclick="OpenAddColumnDialog">＋ Column</button>

            <span class="xdivider"></span>

            <button class="tbtn @(_showFilters ? "tbtn-warn-on" : "tbtn-warn")"
                    type="button" @onclick="() => _showFilters = !_showFilters">
                ⚙ Filters
            </button>
            @if (HasFilters)
            {
                <button class="tbtn tbtn-err" type="button" @onclick="ClearAllFilters">✕ Clear</button>
            }

            <span class="xdivider"></span>

            <button class="tbtn tbtn-success" type="button"
                    disabled="@(_filtered.Count == 0)"
                    @onclick="() => ExportData(false)">
                ⬇ Export (@_filtered.Count)
            </button>
            <button class="tbtn tbtn-success" type="button"
                    disabled="@(_allRecords.Count == 0)"
                    @onclick="() => ExportData(true)">
                ⬇ All (@_allRecords.Count)
            </button>
            <button class="tbtn tbtn-sec" type="button" @onclick="DownloadTemplate">📄 Template</button>
        </div>
    </div>

    @* TABLE *@
    <div class="xbody">
        @if (_allRecords.Count == 0)
        {
            <div style="text-align:center; padding:60px 20px; color:#888;">
                <div style="font-size:4rem; opacity:.15;">📋</div>
                <div style="font-size:1.1rem; font-weight:600; margin-bottom:8px;">No data loaded</div>
                <div style="margin-bottom:16px;">Go to <strong>Uploads</strong> to import an Excel file.</div>
                <a href="/upload"
                   style="background:#1074d6; color:white; padding:8px 18px; border-radius:6px;
                          text-decoration:none; font-size:13px;">⬆ Upload Data</a>
            </div>
        }
        else
        {
            <table class="xt">
                <thead>
                    <tr>
                        <th class="xrn nc">#</th>
                        @foreach (var col in VisibleColumns)
                        {
                            var c = col;
                            <th @onclick="() => ToggleSort(c.Key)">
                                @c.Label
                                @if (_sortCol == c.Key)
                                { <span class="xsi">@(_sortAsc ? "▲" : "▼")</span> }
                            </th>
                        }
                        <th class="xac nc" style="border-left:2px solid #c4cfff;">Actions</th>
                        <th class="xaddcol nc" @onclick="OpenAddColumnDialog" title="Add custom column">＋</th>
                    </tr>
                    @if (_showFilters)
                    {
                        <tr class="frow">
                            <th class="xrn nc"></th>
                            @foreach (var col in VisibleColumns)
                            {
                                var c = col;
                                <th><input class="xfi" placeholder="filter..."
                                           value="@GetFilter(c.Key)"
                                           @oninput="e => OnFilterChanged(c.Key, e.Value?.ToString() ?? string.Empty)" /></th>
                            }
                            <th></th><th></th>
                        </tr>
                    }
                </thead>
                <tbody>
                    @foreach (var row in PagedData)
                    {
                        var r = row;
                        <tr class="@(_selectedRow == r.RowNumber ? "xsel" : "")">
                            <td class="xrn" @onclick="() => _selectedRow = r.RowNumber">@r.RowNumber</td>

                            @foreach (var col in VisibleColumns)
                            {
                                var c = col;
                                bool isEdit = _editRow == r.RowNumber && _editCol == c.Key;
                                <td class="@(isEdit ? "xedit" : "")"
                                    @onclick="() => BeginEdit(r.RowNumber, c.Key, GetCellValue(r, c.Key))">
                                    @if (isEdit)
                                    {
                                        <input value="@_editValue"
                                               @oninput="e => _editValue = e.Value?.ToString() ?? string.Empty"
                                               @onblur="CommitEdit"
                                               @onkeydown="HandleEditKey"
                                               @ref="_editInputRef" />
                                    }
                                    else
                                    {
                                        @GetDisplayValue(r, c.Key)
                                    }
                                </td>
                            }

                            <td class="xac" @onclick:stopPropagation="true">
                                <button class="xbtn xbtn-edit" type="button"
                                        title="Edit row"
                                        @onclick="() => OpenEditRowDialog(r)"
                                        @onclick:stopPropagation="true">✏</button>
                                <button class="xbtn xbtn-del" type="button"
                                        title="Delete row"
                                        @onclick="() => AskDelete(r)"
                                        @onclick:stopPropagation="true">🗑</button>
                            </td>
                            <td></td>
                        </tr>
                    }
                    @if (PagedData.Count == 0)
                    {
                        <tr>
                            <td colspan="@(VisibleColumns.Count + 3)"
                                style="text-align:center; padding:32px; color:#999; font-style:italic;">
                                No records match current filters. &nbsp;
                                <a href="javascript:void(0)" style="color:#1074d6;"
                                   @onclick="ClearAllFilters">Clear filters</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @* PAGINATION *@
    @if (_allRecords.Count > 0)
    {
        <div class="xfoot">
            <span style="font-size:12px; color:#666;">
                @if (_filtered.Count > 0)
                {
                    <text>Rows @(_page * _pageSize + 1)–@(Math.Min((_page+1)*_pageSize, _filtered.Count)) of @_filtered.Count</text>
                }
                @if (HasFilters) { <text> &nbsp;(of @_allRecords.Count total)</text> }
            </span>
            <div style="flex:1;"></div>
            <span style="font-size:12px; color:#666;">Rows per page:</span>
            <select class="pgsel" value="@_pageSize" @onchange="OnPageSizeChanged">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="500">500</option>
            </select>
            <button class="pgbtn" type="button" disabled="@(_page == 0)"
                    @onclick="() => GoToPage(0)">⏮</button>
            <button class="pgbtn" type="button" disabled="@(_page == 0)"
                    @onclick="() => GoToPage(_page - 1)">◀</button>
            <span style="font-size:12px; min-width:60px; text-align:center; color:#444;">
                @(_page + 1) / @TotalPages
            </span>
            <button class="pgbtn" type="button" disabled="@(_page >= TotalPages - 1)"
                    @onclick="() => GoToPage(_page + 1)">▶</button>
            <button class="pgbtn" type="button" disabled="@(_page >= TotalPages - 1)"
                    @onclick="() => GoToPage(TotalPages - 1)">⏭</button>
        </div>
    }

</div>
</div>

@code {
    // ── Column definitions ──────────────────────────────────────────────────
    private record ColDef(string Key, string Label, bool IsCustom = false);

    private static readonly List<ColDef> FixedCols = new()
    {
        new("Name",              "Name"),
        new("Surname",           "Surname"),
        new("Identifier",        "Identifier"),
        new("EmailAddress",      "Email"),
        new("LocalMunicipality", "Municipality"),
        new("HostCompany",       "Host Company"),
        new("LeadCompany",       "Lead Company"),
        new("JobType",           "Job Type"),
        new("DemographicGroup",  "Demographic"),
        new("Sex",               "Sex"),
        new("ContactDetails",    "Contact"),
        new("EmploymentStatus",  "Emp. Status"),
        new("PersonDisability",  "Disability"),
    };

    private List<string> _customColumnNames = new();
    private Dictionary<int, Dictionary<string, string>> _customValues = new();

    private IReadOnlyList<ColDef> VisibleColumns =>
        FixedCols.Concat(_customColumnNames.Select(n => new ColDef(n, n, true))).ToList();

    // ── Data ────────────────────────────────────────────────────────────────
    private List<PersonRecord> _allRecords = new();
    private List<PersonRecord> _filtered   = new();

    private int _page     = 0;
    private int _pageSize = 25;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)_filtered.Count / _pageSize));
    private List<PersonRecord> PagedData =>
        _filtered.Skip(_page * _pageSize).Take(_pageSize).ToList();

    private string _sortCol = string.Empty;
    private bool   _sortAsc = true;
    private int?   _selectedRow;

    // ── Filters ─────────────────────────────────────────────────────────────
    private string _globalSearch = string.Empty;
    private bool   _showFilters;
    private bool   _aiFilterActive;   // shows "Dash filter" badge
    private Dictionary<string, string> _colFilters = new();
    private string GetFilter(string k) => _colFilters.TryGetValue(k, out var v) ? v : string.Empty;
    private void OnFilterChanged(string k, string val) { _colFilters[k] = val; _aiFilterActive = false; _page = 0; ApplyFilters(); }
    private void OnGlobalSearchInput(ChangeEventArgs e) { _globalSearch = e.Value?.ToString() ?? string.Empty; _aiFilterActive = false; _page = 0; ApplyFilters(); }
    private bool HasFilters => !string.IsNullOrWhiteSpace(_globalSearch) || _colFilters.Any(f => !string.IsNullOrWhiteSpace(f.Value));
    private int ActiveFilterCount => (string.IsNullOrWhiteSpace(_globalSearch) ? 0 : 1) + _colFilters.Count(f => !string.IsNullOrWhiteSpace(f.Value));

    // ── Inline edit ─────────────────────────────────────────────────────────
    private int?    _editRow;
    private string? _editCol;
    private string  _editValue = string.Empty;
    private ElementReference _editInputRef;
    private bool    _needsFocus;
    private bool    _suppressRefresh;

    // ── Dialog state ────────────────────────────────────────────────────────
    private bool _showRowDialog;
    private bool _isNewRecord;
    private PersonRecord? _dialogRecord;
    private Dictionary<string, string> _dialogCustomValues = new();

    private bool   _showColDialog;
    private string _newColName = string.Empty;

    private bool _showDeleteConfirm;
    private PersonRecord? _deleteTarget;

    // ── Lifecycle ────────────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        DataService.OnDataChanged += Refresh;
        AiAgent.OnDataTableCommand += HandleAiCommand;

        Refresh();

        // Pick up any pending AI command (e.g. navigated here from chat action)
        var pending = AiAgent.ConsumePendingCommand();
        if (pending != null) HandleAiCommand(pending);
    }

    public void Dispose()
    {
        DataService.OnDataChanged -= Refresh;
        AiAgent.OnDataTableCommand -= HandleAiCommand;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsFocus)
        {
            _needsFocus = false;
            try { await _editInputRef.FocusAsync(); } catch { }
        }
    }

    private void Refresh()
    {
        if (_suppressRefresh) return;
        _allRecords = DataService.GetRecords();
        ApplyFilters();
        InvokeAsync(StateHasChanged);
    }

    // ── AI Command Handler ───────────────────────────────────────────────────
    private void HandleAiCommand(DataTableCommand cmd)
    {
        switch (cmd.Type)
        {
            case "filter":
                if (cmd.Parameters.TryGetValue("column", out var col) &&
                    cmd.Parameters.TryGetValue("value",  out var val))
                {
                    _globalSearch = string.Empty;
                    _colFilters.Clear();
                    _colFilters[col] = val;
                    _showFilters     = true;
                    _aiFilterActive  = true;
                    _page = 0;
                    ApplyFilters();
                    Snackbar.Add($"🤖 Dash filtered by {col}: \"{val}\" — {_filtered.Count} result(s)", Severity.Info,
                        cfg => { cfg.VisibleStateDuration = 4000; });
                }
                break;

            case "export":
                if (cmd.Parameters.TryGetValue("column", out var ecol) &&
                    cmd.Parameters.TryGetValue("value",  out var eval))
                {
                    _globalSearch = string.Empty;
                    _colFilters.Clear();
                    _colFilters[ecol] = eval;
                    _aiFilterActive   = true;
                    ApplyFilters();
                    Snackbar.Add($"🤖 Dash: exporting {_filtered.Count} records where {ecol} = \"{eval}\"", Severity.Success);
                    _ = ExportData(false);
                }
                break;

            case "clear_filters":
                _aiFilterActive = false;
                ClearAllFilters();
                Snackbar.Add("🤖 Dash cleared all filters", Severity.Info,
                    cfg => { cfg.VisibleStateDuration = 3000; });
                break;
        }

        InvokeAsync(StateHasChanged);
    }

    // ── Filter / Sort ────────────────────────────────────────────────────────
    private void ApplyFilters()
    {
        var q = _allRecords.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_globalSearch))
        {
            var t = _globalSearch.Trim();
            q = q.Where(r =>
                CI(r.Name, t) || CI(r.Surname, t) || CI(r.Identifier, t) ||
                CI(r.EmailAddress, t) || CI(r.LocalMunicipality, t) ||
                CI(r.HostCompany, t) || CI(r.LeadCompany, t) || CI(r.JobType, t) ||
                CI(r.DemographicGroup, t) || CI(r.Sex, t) || CI(r.ContactDetails, t) ||
                CI(r.EmploymentStatus, t) || CI(r.PersonDisability, t) ||
                _customColumnNames.Any(cn => CI(GetCustomValue(r.RowNumber, cn), t)));
        }

        foreach (var kv in _colFilters.Where(f => !string.IsNullOrWhiteSpace(f.Value)))
        {
            var term = kv.Value.Trim(); var key = kv.Key;
            q = q.Where(r => CI(GetCellValue(r, key), term));
        }

        if (!string.IsNullOrWhiteSpace(_sortCol))
            q = _sortAsc
                ? q.OrderBy(r => GetCellValue(r, _sortCol), StringComparer.OrdinalIgnoreCase)
                : q.OrderByDescending(r => GetCellValue(r, _sortCol), StringComparer.OrdinalIgnoreCase);

        _filtered = q.ToList();
        if (_page >= TotalPages) _page = Math.Max(0, TotalPages - 1);
    }

    private void ToggleSort(string col)
    {
        if (_sortCol == col) _sortAsc = !_sortAsc;
        else { _sortCol = col; _sortAsc = true; }
        _page = 0; ApplyFilters();
    }

    private void ClearAllFilters() { _globalSearch = string.Empty; _colFilters.Clear(); _aiFilterActive = false; ApplyFilters(); }
    private void OnPageSizeChanged(ChangeEventArgs e) { if (int.TryParse(e.Value?.ToString(), out var s)) { _pageSize = s; _page = 0; } }
    private void GoToPage(int p) => _page = Math.Clamp(p, 0, TotalPages - 1);
    private static bool CI(string src, string term) => (src ?? "").Contains(term, StringComparison.OrdinalIgnoreCase);

    // ── Cell helpers ─────────────────────────────────────────────────────────
    private string GetCellValue(PersonRecord r, string key) => key switch
    {
        "Name"              => r.Name,
        "Surname"           => r.Surname,
        "Identifier"        => r.Identifier,
        "EmailAddress"      => r.EmailAddress,
        "LocalMunicipality" => r.LocalMunicipality,
        "HostCompany"       => r.HostCompany,
        "LeadCompany"       => r.LeadCompany,
        "JobType"           => r.JobType,
        "DemographicGroup"  => r.DemographicGroup,
        "Sex"               => r.Sex,
        "ContactDetails"    => r.ContactDetails,
        "EmploymentStatus"  => r.EmploymentStatus,
        "PersonDisability"  => r.PersonDisability,
        _                   => GetCustomValue(r.RowNumber, key),
    };

    private MarkupString GetDisplayValue(PersonRecord r, string key)
    {
        var raw = GetCellValue(r, key);
        if (key == "Sex" && !string.IsNullOrWhiteSpace(raw))
        {
            var cls = raw.Equals("Female", StringComparison.OrdinalIgnoreCase) ? "xchip-f" : "xchip-m";
            return new MarkupString($"<span class='xchip {cls}'>{System.Net.WebUtility.HtmlEncode(raw)}</span>");
        }
        if (key == "PersonDisability" && r.HasDisability)
            return new MarkupString("<span class='xchip xchip-y'>Yes</span>");
        return new MarkupString(System.Net.WebUtility.HtmlEncode(raw));
    }

    private void SetCellValue(PersonRecord r, string key, string val)
    {
        switch (key)
        {
            case "Name":              r.Name              = val; break;
            case "Surname":           r.Surname           = val; break;
            case "Identifier":        r.Identifier        = val; break;
            case "EmailAddress":      r.EmailAddress      = val; break;
            case "LocalMunicipality": r.LocalMunicipality = val; break;
            case "HostCompany":       r.HostCompany       = val; break;
            case "LeadCompany":       r.LeadCompany       = val; break;
            case "JobType":           r.JobType           = val; break;
            case "DemographicGroup":  r.DemographicGroup  = val; break;
            case "Sex":               r.Sex               = val; break;
            case "ContactDetails":    r.ContactDetails    = val; break;
            case "EmploymentStatus":  r.EmploymentStatus  = val; break;
            case "PersonDisability":  r.PersonDisability  = val; break;
            default:
                if (!_customValues.ContainsKey(r.RowNumber)) _customValues[r.RowNumber] = new();
                _customValues[r.RowNumber][key] = val;
                break;
        }
    }

    private string GetCustomValue(int rowNum, string col)
    {
        if (_customValues.TryGetValue(rowNum, out var d) && d.TryGetValue(col, out var v)) return v;
        return string.Empty;
    }

    private bool IsFixedColumn(string key) => FixedCols.Any(c => c.Key == key);

    // ── Inline edit ──────────────────────────────────────────────────────────
    private void BeginEdit(int rowNum, string colKey, string currentValue)
    {
        if (_editRow == rowNum && _editCol == colKey) return;
        if (_editRow is not null) CommitEdit();
        _editRow = rowNum; _editCol = colKey;
        _editValue = currentValue; _selectedRow = rowNum; _needsFocus = true;
    }

    private void CommitEdit()
    {
        if (_editRow is null || _editCol is null) return;
        var record = _allRecords.FirstOrDefault(r => r.RowNumber == _editRow);
        if (record != null)
        {
            var oldVal = GetCellValue(record, _editCol);
            if (oldVal != _editValue)
            {
                SetCellValue(record, _editCol, _editValue);
                if (IsFixedColumn(_editCol))
                {
                    _suppressRefresh = true;
                    DataService.UpdateRecord(record);
                    _suppressRefresh = false;
                    ApplyFilters();
                }
            }
        }
        _editRow = null; _editCol = null; _editValue = string.Empty;
    }

    private void HandleEditKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")  CommitEdit();
        if (e.Key == "Escape") { _editRow = null; _editCol = null; _editValue = string.Empty; }
    }

    // ── Add / Edit Row dialog ────────────────────────────────────────────────
    private void OpenAddRowDialog()
    {
        CommitEdit();
        _dialogRecord = new PersonRecord();
        _dialogCustomValues = _customColumnNames.ToDictionary(n => n, _ => string.Empty);
        _isNewRecord = true; _showRowDialog = true;
    }

    private void OpenEditRowDialog(PersonRecord r)
    {
        CommitEdit();
        _dialogRecord = new PersonRecord
        {
            RowNumber = r.RowNumber, Name = r.Name, Surname = r.Surname,
            Identifier = r.Identifier, EmailAddress = r.EmailAddress,
            LocalMunicipality = r.LocalMunicipality, HostCompany = r.HostCompany,
            LeadCompany = r.LeadCompany, JobType = r.JobType,
            DemographicGroup = r.DemographicGroup, Sex = r.Sex,
            ContactDetails = r.ContactDetails, EmploymentStatus = r.EmploymentStatus,
            PersonDisability = r.PersonDisability
        };
        _dialogCustomValues = _customColumnNames.ToDictionary(n => n, n => GetCustomValue(r.RowNumber, n));
        _isNewRecord = false; _showRowDialog = true;
    }

    private void SaveRow()
    {
        if (_dialogRecord is null) return;
        if (string.IsNullOrWhiteSpace(_dialogRecord.Name) && string.IsNullOrWhiteSpace(_dialogRecord.Surname))
        { Snackbar.Add("Name or Surname is required.", Severity.Warning); return; }

        if (_isNewRecord)
        {
            DataService.AddRecord(_dialogRecord);
            Snackbar.Add($"Row added: {_dialogRecord.Name} {_dialogRecord.Surname}.", Severity.Success);
        }
        else
        {
            DataService.UpdateRecord(_dialogRecord);
            Snackbar.Add("Row updated.", Severity.Success);
        }

        var rowNum = _dialogRecord.RowNumber;
        foreach (var kv in _dialogCustomValues)
        {
            if (!_customValues.ContainsKey(rowNum)) _customValues[rowNum] = new();
            _customValues[rowNum][kv.Key] = kv.Value;
        }
        CloseRowDialog();
    }

    private void CloseRowDialog() { _showRowDialog = false; _dialogRecord = null; _dialogCustomValues = new(); }

    // ── Delete ───────────────────────────────────────────────────────────────
    private void AskDelete(PersonRecord r) { CommitEdit(); _deleteTarget = r; _showDeleteConfirm = true; }

    private void ExecuteDelete()
    {
        if (_deleteTarget is null) return;
        _customValues.Remove(_deleteTarget.RowNumber);
        DataService.DeleteRecord(_deleteTarget.RowNumber);
        Snackbar.Add($"Row #{_deleteTarget.RowNumber} deleted.", Severity.Info);
        _showDeleteConfirm = false; _deleteTarget = null;
    }

    // ── Custom column ────────────────────────────────────────────────────────
    private void OpenAddColumnDialog() { _newColName = string.Empty; _showColDialog = true; }

    private void HandleColKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") AddCustomColumn(); }

    private void AddCustomColumn()
    {
        var name = _newColName.Trim();
        if (string.IsNullOrWhiteSpace(name)) { Snackbar.Add("Column name cannot be empty.", Severity.Warning); return; }
        if (_customColumnNames.Contains(name, StringComparer.OrdinalIgnoreCase) ||
            FixedCols.Any(c => c.Key.Equals(name, StringComparison.OrdinalIgnoreCase) ||
                               c.Label.Equals(name, StringComparison.OrdinalIgnoreCase)))
        { Snackbar.Add($"Column '{name}' already exists.", Severity.Warning); return; }

        _customColumnNames.Add(name);
        _showColDialog = false; _newColName = string.Empty;
        Snackbar.Add($"Column '{name}' added.", Severity.Success);
    }

    // ── Export ───────────────────────────────────────────────────────────────
    private async Task ExportData(bool allData)
    {
        try
        {
            CommitEdit();
            var records = allData ? _allRecords : _filtered;
            if (records.Count == 0) { Snackbar.Add("No records to export.", Severity.Warning); return; }
            var bytes  = BuildExportBytes(records);
            var b64    = Convert.ToBase64String(bytes);
            var fname  = $"Participants_{(allData ? "All" : "Filtered")}_{DateTime.Now:yyyyMMdd_HHmm}.xlsx";
            await JS.InvokeVoidAsync("downloadFileBase64", fname,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", b64);
            Snackbar.Add($"Exported {records.Count} records.", Severity.Success);
        }
        catch (Exception ex) { Logger.LogError(ex, "Export error"); Snackbar.Add($"Export failed: {ex.Message}", Severity.Error); }
    }

    private byte[] BuildExportBytes(List<PersonRecord> records)
    {
        using var pkg = new ExcelPackage();
        var ws = pkg.Workbook.Worksheets.Add("Participants");
        var headers = new List<string> { "#","Name","Surname","Identifier","Email Address",
            "Local Municipality","Host Company","Lead Company","Job Type","Demographic Group",
            "Sex","Contact Details","Employment Status","Person Disability" };
        headers.AddRange(_customColumnNames);

        for (int c = 0; c < headers.Count; c++)
        {
            var cell = ws.Cells[1, c + 1];
            cell.Value = headers[c]; cell.Style.Font.Bold = true;
            cell.Style.Fill.PatternType = ExcelFillStyle.Solid;
            cell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.FromArgb(0x10, 0x74, 0xD6));
            cell.Style.Font.Color.SetColor(System.Drawing.Color.White);
        }

        int row = 2;
        foreach (var r in records)
        {
            ws.Cells[row,1].Value=r.RowNumber; ws.Cells[row,2].Value=r.Name;
            ws.Cells[row,3].Value=r.Surname;   ws.Cells[row,4].Value=r.Identifier;
            ws.Cells[row,5].Value=r.EmailAddress; ws.Cells[row,6].Value=r.LocalMunicipality;
            ws.Cells[row,7].Value=r.HostCompany;  ws.Cells[row,8].Value=r.LeadCompany;
            ws.Cells[row,9].Value=r.JobType;      ws.Cells[row,10].Value=r.DemographicGroup;
            ws.Cells[row,11].Value=r.Sex;          ws.Cells[row,12].Value=r.ContactDetails;
            ws.Cells[row,13].Value=r.EmploymentStatus; ws.Cells[row,14].Value=r.PersonDisability;
            for (int c = 0; c < _customColumnNames.Count; c++)
                ws.Cells[row, 15 + c].Value = GetCustomValue(r.RowNumber, _customColumnNames[c]);
            if (row % 2 == 0)
            {
                using var rng = ws.Cells[row, 1, row, headers.Count];
                rng.Style.Fill.PatternType = ExcelFillStyle.Solid;
                rng.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.FromArgb(0xF0, 0xF4, 0xFF));
            }
            row++;
        }
        if (ws.Dimension != null) ws.Cells[ws.Dimension.Address].AutoFitColumns();
        return pkg.GetAsByteArray();
    }

    private async Task DownloadTemplate()
    {
        try
        {
            var bytes = DataService.GenerateTemplate();
            var b64   = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileBase64", "ParticipantTemplate.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", b64);
            Snackbar.Add("Template downloaded.", Severity.Info);
        }
        catch (Exception ex) { Logger.LogError(ex, "Template error"); Snackbar.Add($"Failed: {ex.Message}", Severity.Error); }
    }
}
