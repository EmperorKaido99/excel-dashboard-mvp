@using ExcelDashboardMVP.Models
@using ExcelDashboardMVP.Services
@inject AiAgentService AiAgent
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<style>
    /* ── Container ────────────────────────────────────────────────────────── */
    .dash-wrap {
        position: fixed;
        bottom: 24px; right: 24px;
        z-index: 99998;
        display: flex; flex-direction: column; align-items: flex-end; gap: 12px;
        pointer-events: none;
    }
    .dash-wrap > * { pointer-events: all; }

    /* ── FAB button ───────────────────────────────────────────────────────── */
    .dash-fab {
        width: 58px; height: 58px; border-radius: 50%;
        background: linear-gradient(135deg, #1074d6 0%, #1e2393 100%);
        border: none; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: 26px; color: white;
        box-shadow: 0 4px 20px rgba(16,116,214,.45);
        transition: transform .2s, box-shadow .2s;
        position: relative;
    }
    .dash-fab:hover { transform: scale(1.1); box-shadow: 0 6px 28px rgba(16,116,214,.55); }
    .dash-fab-open  { transform: rotate(90deg) scale(1.05); }
    .dash-fab-open:hover { transform: rotate(90deg) scale(1.12); }

    .dash-fab-badge {
        position: absolute; top: 2px; right: 2px;
        background: #f44336; color: white; border-radius: 10px;
        font-size: 10px; font-weight: 700;
        min-width: 18px; height: 18px; padding: 0 4px;
        display: flex; align-items: center; justify-content: center;
        border: 2px solid white;
    }

    /* ── Panel ────────────────────────────────────────────────────────────── */
    .dash-panel {
        width: 370px;
        max-height: 580px;
        background: white;
        border-radius: 18px;
        box-shadow: 0 8px 40px rgba(0,0,0,.22);
        display: flex; flex-direction: column;
        overflow: hidden;
        animation: dashSlideIn .22s cubic-bezier(.34,1.56,.64,1);
    }
    @@keyframes dashSlideIn {
        from { opacity:0; transform: translateY(20px) scale(.95); }
        to   { opacity:1; transform: translateY(0)   scale(1);    }
    }

    /* ── Header ───────────────────────────────────────────────────────────── */
    .dash-header {
        background: linear-gradient(135deg, #1074d6 0%, #1e2393 100%);
        padding: 14px 16px;
        display: flex; align-items: center; justify-content: space-between;
        flex-shrink: 0;
    }
    .dash-header-left { display: flex; align-items: center; gap: 10px; }
    .dash-header-avatar {
        width: 38px; height: 38px; border-radius: 50%;
        background: rgba(255,255,255,.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 20px;
    }
    .dash-header-name  { color: white; font-weight: 700; font-size: 15px; }
    .dash-header-status {
        color: rgba(255,255,255,.75); font-size: 11px; margin-top: 1px;
        display: flex; align-items: center; gap: 4px;
    }
    .dash-status-dot {
        width: 7px; height: 7px; border-radius: 50%;
        background: #4caf50; display: inline-block;
    }
    .dash-status-dot-typing { background: #ffc107; animation: dashPulse 1s infinite; }
    @@keyframes dashPulse { 0%,100%{opacity:1} 50%{opacity:.4} }

    .dash-header-btn {
        background: rgba(255,255,255,.15); border: none;
        color: white; cursor: pointer; border-radius: 7px;
        width: 30px; height: 30px; font-size: 14px;
        display: flex; align-items: center; justify-content: center;
        transition: background .15s;
    }
    .dash-header-btn:hover { background: rgba(255,255,255,.28); }

    /* ── Messages ─────────────────────────────────────────────────────────── */
    .dash-messages {
        flex: 1; overflow-y: auto; padding: 16px 14px;
        display: flex; flex-direction: column; gap: 12px;
        min-height: 0;
    }
    .dash-messages::-webkit-scrollbar { width: 4px; }
    .dash-messages::-webkit-scrollbar-thumb { background: #d0d8f0; border-radius: 4px; }

    /* ── Welcome screen ───────────────────────────────────────────────────── */
    .dash-welcome {
        display: flex; flex-direction: column; align-items: center;
        text-align: center; padding: 12px 6px; gap: 8px;
    }
    .dash-welcome-icon { font-size: 48px; }
    .dash-welcome-title { font-size: 18px; font-weight: 700; color: #1e2393; }
    .dash-welcome-sub   { font-size: 12px; color: #666; line-height: 1.5; max-width: 280px; }

    .dash-suggestions {
        display: flex; flex-wrap: wrap; gap: 6px;
        justify-content: center; margin-top: 6px;
    }
    .dash-sug-btn {
        border: 1px solid #c4cfff; border-radius: 20px;
        background: #f5f7ff; color: #1074d6;
        padding: 5px 12px; font-size: 11.5px; cursor: pointer;
        font-family: inherit; transition: all .15s;
    }
    .dash-sug-btn:hover { background: #1074d6; color: white; border-color: #1074d6; }

    /* ── Message bubbles ──────────────────────────────────────────────────── */
    .dash-msg { display: flex; gap: 8px; align-items: flex-end; }
    .dash-msg-user { flex-direction: row-reverse; }

    .dash-msg-avatar {
        width: 30px; height: 30px; border-radius: 50%;
        background: #eef2ff; font-size: 16px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .dash-bubble {
        max-width: 260px; padding: 9px 12px; border-radius: 16px;
        font-size: 13px; line-height: 1.5; word-wrap: break-word;
    }
    .dash-bubble-ai   { background: #f0f4ff; color: #1a1a2e; border-bottom-left-radius: 4px; }
    .dash-bubble-user { background: #1074d6; color: white; border-bottom-right-radius: 4px; }

    .dash-bubble-wrap { display: flex; flex-direction: column; gap: 6px; max-width: 280px; }

    /* ── Loading dots ─────────────────────────────────────────────────────── */
    .dash-dots { display: flex; gap: 4px; padding: 4px 0; align-items: center; }
    .dash-dots span {
        width: 7px; height: 7px; border-radius: 50%; background: #90a0c8;
        animation: dashDot 1.2s infinite;
    }
    .dash-dots span:nth-child(2) { animation-delay: .2s; }
    .dash-dots span:nth-child(3) { animation-delay: .4s; }
    @@keyframes dashDot { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-5px)} }

    /* ── Action buttons ───────────────────────────────────────────────────── */
    .dash-actions { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 4px; }
    .dash-act-btn {
        border: 1px solid #c4cfff; border-radius: 14px;
        background: white; color: #1074d6;
        padding: 4px 11px; font-size: 11.5px; cursor: pointer;
        font-family: inherit; font-weight: 500;
        display: flex; align-items: center; gap: 4px;
        transition: all .15s;
        box-shadow: 0 1px 4px rgba(16,116,214,.1);
    }
    .dash-act-btn:hover { background: #1074d6; color: white; border-color: #1074d6; }

    /* ── Timestamp ────────────────────────────────────────────────────────── */
    .dash-ts { font-size: 10px; color: #aaa; text-align: right; margin-top: 1px; }

    /* ── Input ────────────────────────────────────────────────────────────── */
    .dash-input-area {
        flex-shrink: 0;
        border-top: 1px solid #e8ecf8;
        padding: 10px 12px;
        display: flex; gap: 8px; align-items: center;
        background: #fafbff;
    }
    .dash-input {
        flex: 1; border: 1px solid #c4cfff; border-radius: 20px;
        padding: 8px 14px; font-size: 13px; font-family: inherit;
        outline: none; background: white;
        transition: border-color .15s;
    }
    .dash-input:focus { border-color: #1074d6; }
    .dash-input:disabled { background: #f5f5f5; }

    .dash-send {
        width: 36px; height: 36px; border-radius: 50%;
        background: #1074d6; color: white; border: none;
        cursor: pointer; font-size: 16px;
        display: flex; align-items: center; justify-content: center;
        transition: background .15s, transform .1s;
        flex-shrink: 0;
    }
    .dash-send:hover:not(:disabled) { background: #1e2393; transform: scale(1.08); }
    .dash-send:disabled { background: #c0caed; cursor: default; }

    /* ── Powered by ───────────────────────────────────────────────────────── */
    .dash-footer {
        text-align: center; font-size: 10px; color: #bbb;
        padding: 4px; background: #fafbff; border-top: 1px solid #f0f2fa;
    }
</style>

<div class="dash-wrap">

    @* ── Chat Panel ────────────────────────────────────────────────────── *@
    @if (_isOpen)
    {
        <div class="dash-panel">

            @* Header *@
            <div class="dash-header">
                <div class="dash-header-left">
                    <div class="dash-header-avatar">🤖</div>
                    <div>
                        <div class="dash-header-name">Dash AI</div>
                        <div class="dash-header-status">
                            <span class="dash-status-dot @(_isTyping ? "dash-status-dot-typing" : "")"></span>
                            @(_isTyping ? "thinking..." : "online · powered by Gemini")
                        </div>
                    </div>
                </div>
                <button class="dash-header-btn" type="button"
                        @onclick="ClearHistory" title="Clear conversation">🗑</button>
            </div>

            @* Messages *@
            <div class="dash-messages" id="dash-msg-box">

                @if (!_messages.Any())
                {
                    <div class="dash-welcome">
                        <div class="dash-welcome-icon">🤖</div>
                        <div class="dash-welcome-title">Hi, I'm Dash!</div>
                        <div class="dash-welcome-sub">
                            Your smart assistant for this dashboard. I can answer questions about your data,
                            navigate pages, filter records, and export exactly what you need.
                        </div>
                        <div class="dash-suggestions">
                            @foreach (var s in _quickSuggestions)
                            {
                                var suggestion = s;
                                <button class="dash-sug-btn" type="button"
                                        @onclick="() => SendSuggestion(suggestion)">
                                    @suggestion
                                </button>
                            }
                        </div>
                    </div>
                }

                @foreach (var msg in _messages)
                {
                    bool isUser = msg.Role == "user";
                    <div class="dash-msg @(isUser ? "dash-msg-user" : "")">
                        @if (!isUser)
                        {
                            <div class="dash-msg-avatar">🤖</div>
                        }
                        <div class="dash-bubble-wrap">
                            <div class="dash-bubble @(isUser ? "dash-bubble-user" : "dash-bubble-ai")">
                                @if (msg.IsLoading)
                                {
                                    <div class="dash-dots">
                                        <span></span><span></span><span></span>
                                    </div>
                                }
                                else
                                {
                                    @msg.Content
                                }
                            </div>
                            @if (!isUser && msg.Actions.Any() && !msg.IsLoading)
                            {
                                <div class="dash-actions">
                                    @foreach (var action in msg.Actions)
                                    {
                                        var a = action;
                                        <button class="dash-act-btn" type="button"
                                                @onclick="() => ExecuteAction(a)">
                                            @GetActionIcon(a.Type) @a.Label
                                        </button>
                                    }
                                </div>
                            }
                            <div class="dash-ts">@msg.Timestamp.ToString("HH:mm")</div>
                        </div>
                    </div>
                }
            </div>

            @* Input *@
            <div class="dash-input-area">
                <input class="dash-input"
                       @bind="_inputText"
                       @bind:event="oninput"
                       @onkeydown="HandleKeyDown"
                       placeholder="Ask Dash anything..."
                       disabled="@_isTyping"
                       maxlength="500" />
                <button class="dash-send" type="button"
                        @onclick="SendMessage"
                        disabled="@(string.IsNullOrWhiteSpace(_inputText) || _isTyping)">
                    ➤
                </button>
            </div>

            <div class="dash-footer">Powered by Gemini · Data stays local</div>
        </div>
    }

    @* ── FAB ───────────────────────────────────────────────────────────── *@
    <button class="dash-fab @(_isOpen ? "dash-fab-open" : "")"
            type="button"
            title="@(_isOpen ? "Close Dash AI" : "Open Dash AI")"
            @onclick="TogglePanel">
        @if (_isOpen) { <span>✕</span> }
        else
        {
            <span>🤖</span>
            @if (_unread > 0)
            {
                <span class="dash-fab-badge">@_unread</span>
            }
        }
    </button>
</div>

@code {
    private bool   _isOpen;
    private bool   _isTyping;
    private int    _unread;
    private string _inputText = "";
    private readonly List<ChatMessage> _messages = new();

    private readonly string[] _quickSuggestions = new[]
    {
        "📊 What data is loaded?",
        "👥 How many female participants?",
        "🏢 Who are the top host companies?",
        "📋 Take me to the data table",
        "🔍 Filter by a host company",
        "📤 Export all participants"
    };

    // ── Lifecycle ──────────────────────────────────────────────────────────
    protected override void OnInitialized() { /* nothing needed */ }

    public void Dispose() { /* nothing to unsubscribe */ }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_messages.Any())
        {
            try
            {
                await JS.InvokeVoidAsync("eval",
                    "var c=document.getElementById('dash-msg-box'); if(c) c.scrollTop=c.scrollHeight;");
            }
            catch { /* ignore if page transitions */ }
        }
    }

    // ── UI handlers ────────────────────────────────────────────────────────
    private void TogglePanel()
    {
        _isOpen = !_isOpen;
        if (_isOpen) _unread = 0;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_inputText) && !_isTyping)
            await SendMessage();
    }

    private async Task SendSuggestion(string text)
    {
        _inputText = text;
        await SendMessage();
    }

    private async Task SendMessage()
    {
        var text = _inputText.Trim();
        if (string.IsNullOrWhiteSpace(text) || _isTyping) return;
        _inputText = "";

        // Add user message
        _messages.Add(new ChatMessage { Role = "user", Content = text });

        // Add loading placeholder
        var loader = new ChatMessage { Role = "assistant", Content = "", IsLoading = true };
        _messages.Add(loader);
        _isTyping = true;
        StateHasChanged();

        // Call AI
        var response = await AiAgent.SendMessageAsync(text);

        // Replace loader with actual response
        _messages.Remove(loader);
        _messages.Add(new ChatMessage
        {
            Role    = "assistant",
            Content = response.Message,
            Actions = response.Actions ?? new()
        });

        _isTyping = false;
        if (!_isOpen) _unread++;
        StateHasChanged();
    }

    // ── Action execution ───────────────────────────────────────────────────
    private async Task ExecuteAction(AiAction action)
    {
        switch (action.Type)
        {
            case "navigate":
                if (!string.IsNullOrWhiteSpace(action.Route))
                {
                    _isOpen = false;
                    Nav.NavigateTo(action.Route);
                }
                break;

            case "filter":
            {
                var cmd = new DataTableCommand
                {
                    Type = "filter",
                    Parameters = new()
                    {
                        ["column"] = action.Column ?? "",
                        ["value"]  = action.Value  ?? ""
                    }
                };
                AiAgent.DispatchDataTableCommand(cmd);

                if (!Nav.Uri.Contains("/data-table"))
                {
                    _isOpen = false;
                    Nav.NavigateTo("/data-table");
                }
                break;
            }

            case "export":
            {
                var cmd = new DataTableCommand
                {
                    Type = "export",
                    Parameters = new()
                    {
                        ["column"] = action.Column ?? "",
                        ["value"]  = action.Value  ?? ""
                    }
                };
                AiAgent.DispatchDataTableCommand(cmd);

                if (!Nav.Uri.Contains("/data-table"))
                {
                    _isOpen = false;
                    Nav.NavigateTo("/data-table");
                }
                break;
            }

            case "clear_filters":
                AiAgent.DispatchDataTableCommand(new DataTableCommand { Type = "clear_filters" });
                if (!Nav.Uri.Contains("/data-table"))
                {
                    _isOpen = false;
                    Nav.NavigateTo("/data-table");
                }
                break;
        }

        await Task.CompletedTask;
    }

    private void ClearHistory()
    {
        _messages.Clear();
        AiAgent.ClearHistory();
    }

    // ── Helpers ────────────────────────────────────────────────────────────
    private static string GetActionIcon(string type) => type switch
    {
        "navigate"      => "🔗",
        "filter"        => "🔍",
        "export"        => "📥",
        "clear_filters" => "✕",
        _               => "▶"
    };
}
